											</Properties>
											<Item class="NumberPose" referent="RBXFB86BEDECA3F42EC91B1EA78C9E32F60">
												<Properties>
													<double name="Value">140312253726156</double>
													<token name="EasingDirection">0</token>
													<token name="EasingStyle">0</token>
													<float name="Weight">1</float>
